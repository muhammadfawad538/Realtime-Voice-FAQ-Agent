# Gemini API Key (required for LLM)
# Get your free API key at: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# Optional: Customize default language (BCP 47 tag)
VITE_DEFAULT_LANGUAGE=en-US

# Optional: Enable debug mode for verbose logging
VITE_DEBUG_MODE=false

# Optional: Preferred TTS voice (e.g., en-US-JennyNeural)
VITE_TTS_VOICE=

# Optional: Speech rate (0.5 - 2.0, default: 1.0)
VITE_SPEECH_RATE=1.0

# Optional: Enable high contrast mode for accessibility
VITE_HIGH_CONTRAST=false

# Optional: Enable reduced motion for accessibility
VITE_REDUCED_MOTION=false
